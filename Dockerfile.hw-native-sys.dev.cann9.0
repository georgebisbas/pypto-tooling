# Personal dev layer on top of pypto3-hw-native-sys:cann9.
#
# Bakes personal git identity + fork remote + an editable install so a
# `docker run` drops you straight into a ready-to-hack pypto checkout,
# instead of re-running the same setup by hand every time (see
# pypto-tooling/personal_setup.md).
#
# PREREQUISITE — build the base image first:
#   ./scripts/build-npu-images.sh pypto
#   (or: docker build -t pypto3-hw-native-sys:cann9 - < Dockerfile.hw-native-sys.cann9.0)
#
# BUILD:
#   docker build -t pypto3-dev:cann9 -f Dockerfile.hw-native-sys.dev.cann9.0 .
#
# BUILD (custom identity / fork / base image tag):
#   docker build \
#     --build-arg BASE_IMAGE=pypto3-hw-native-sys:cann9 \
#     --build-arg GIT_USER_NAME="Your Name" \
#     --build-arg GIT_USER_EMAIL="you@example.com" \
#     --build-arg FORK_REMOTE_NAME=fork-yourname \
#     --build-arg FORK_REMOTE_URL=https://github.com/yourname/pypto.git \
#     -t pypto3-dev:cann9 -f Dockerfile.hw-native-sys.dev.cann9.0 .
#
# RUN: identical flags to pypto3-hw-native-sys:cann9 — see that Dockerfile's
# RUN section (single-device vs multi-device/HCCL with --pid=host).
#
# INSIDE CONTAINER (fork already fetched at build time):
#   cd ${PYPTO_DIR}
#   git checkout -b my-branch fork-gbisbas/some-remote-branch
#   pip install --no-build-isolation -e ".[dev]"   # only needed again after checkout
#
# HCCL: LD_PRELOAD is intentionally NOT baked in here either — same VS Code
# attach-hang reason as the base image (debugging_skills/SKILL.md). A
# `hccl-preload` shell function is defined below; call it manually before
# HCCL/distributed tests — defining it does not export anything by itself:
#   hccl-preload && pytest tests/st/distributed/... --platform=a2a3 --device="0,1"

ARG BASE_IMAGE=pypto3-hw-native-sys:cann9
FROM ${BASE_IMAGE}

ARG GIT_USER_NAME="georgebisbas"
ARG GIT_USER_EMAIL="georgios.bismpas@h-partners.com"
ARG FORK_REMOTE_NAME=fork-gbisbas
ARG FORK_REMOTE_URL=https://github.com/georgebisbas/pypto.git

RUN git config --global user.name "${GIT_USER_NAME}" && \
    git config --global user.email "${GIT_USER_EMAIL}" && \
    git config --global pull.rebase true && \
    git config --global --add safe.directory "${PYPTO_DIR}"

# Best-effort: don't fail the build if the fork is unreachable (e.g. offline rebuild).
RUN cd "${PYPTO_DIR}" && \
    git remote add "${FORK_REMOTE_NAME}" "${FORK_REMOTE_URL}" && \
    (git fetch "${FORK_REMOTE_NAME}" || echo "WARNING: could not fetch ${FORK_REMOTE_NAME} at build time — run 'git fetch ${FORK_REMOTE_NAME}' inside the container")

# Base image installs pypto non-editably (pip install ".[dev]"). Re-install
# editable so source edits made inside the container (e.g. after checking out
# a fork branch) take effect without a full reinstall.
RUN cd "${PYPTO_DIR}" && pip install --no-build-isolation -e ".[dev]"

# HCCL preload helper — a function, not an exported var, so it is a no-op
# until explicitly called (safe under VS Code's userEnvProbe).
RUN echo 'hccl-preload() { export LD_PRELOAD="${CANN_HOME}/aarch64-linux/lib64/libhccl.so"; echo "LD_PRELOAD set for this shell: $LD_PRELOAD"; }' >> /etc/bash.bashrc

WORKDIR ${PYPTO_DIR}
CMD ["bash"]
