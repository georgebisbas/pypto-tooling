    "default": {
      "git_status": {
        "command": "git status -sb",
        "category": "git",
        "risk": "safe-read-only",
        "duration_hint": "<10s"
      },
      "last_commit": {
        "command": "git log -1 --oneline",
        "category": "git",
        "risk": "safe-read-only",
        "duration_hint": "<10s"
      },
      "changed_files": {
        "command": "git --no-pager diff --name-only",
